# Copy to .env.local for development; set these in Vercel → Project Settings → Environment Variables for production.

# Public site URL — used in metadata, sitemaps, etc.
# Local dev:  http://localhost:3000
# Production: https://lumemaison.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin panel credentials (used by app/api/admin/auth/route.ts)
ADMIN_USERNAME=manzura
ADMIN_PASSWORD=change-me

# iron-session encryption secret (used by lib/session.ts)
# Generate a fresh 64-char hex string for production: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-64-character-hex-string-from-openssl-rand-hex-32
